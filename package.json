{
  "name": "flowdesk",
  "version": "1.0.0",
  "description": "FlowDesk — demo SPA dla zarządzania usługami",
  "type": "module",
  "scripts": {
    "dev": "npx serve .",
    "pwa:manifest": "node scripts/generate-service-worker-manifest.js",
    "pwa:check": "node scripts/generate-service-worker-manifest.js --check",
    "perf:budget": "node scripts/check-performance-budget.js",
    "lighthouse": "npm run perf:budget",
    "lint": "npm run lint:js && npm run lint:css && npm run format:check",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"css/**/*.css\"",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test tests/e2e",
    "test:a11y": "playwright test tests/a11y",
    "prebuild": "npm run pwa:manifest",
    "build": "npm run build:css && npm run build:js",
    "check": "npm run pwa:check && npm run lint && npm run test && npm run test:e2e && npm run test:a11y && npm run build && npm run perf:budget",
    "build:css": "postcss css/style.css -o css/style.min.css",
    "build:js": "terser js/main.js -o js/main.min.js --module",
    "images": "imagemin assets/images/* --out-dir=assets/images/optimized --plugin=webp"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "cssnano": "^6.1.2",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "imagemin-cli": "^7.0.0",
    "imagemin-webp": "^8.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.47",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "prettier": "^3.9.4",
    "serve": "^14.2.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.36.0",
    "vitest": "^4.1.9"
  }
}
